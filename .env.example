# Deployer wallet private key — NEVER commit the real .env
PRIVATE_KEY=your_private_key_here

# Filled in after forge script deploys the contract
VITE_TPIRATE_ADDRESS=

# For AddLiquidity.s.sol
# Confirm USDC address from: https://docs.tempo.xyz
USDC_ADDRESS=
# Confirm Uniswap v2 Router from: https://docs.uniswap.org (Tempo deployment)
UNISWAP_V2_ROUTER=
# 1,000,000 TPirate in raw units (6 decimals)
INITIAL_TPIRATE=1000000000000
# $10 USDC in raw units (6 decimals)
INITIAL_USDC=10000000
